@model Execute.Sql.Paradox.Models.SqlExecutionResult
@using Execute.Sql.Paradox.Models
@{
    ViewData["Title"] = "Executar SQL";
    var connections = ViewBag.Connections as List<ConnectionConfig> ?? new List<ConnectionConfig>();
    var selectedConn = ViewBag.SelectedConnection as string ?? Model?.ConnectionName ?? string.Empty;
}

<h2 class="mb-4">▶ Executar Comando SQL</h2>

<div class="row">
    <div class="col-12">
        <form asp-controller="Sql" asp-action="Execute" method="post">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white d-flex align-items-center justify-content-between">
                    <span>Comando SQL</span>
                    @if (connections.Any())
                    {
                        <div class="d-flex align-items-center gap-2">
                            <label class="text-white mb-0 me-1">Conexão:</label>
                            <select name="ConnectionName" class="form-select form-select-sm" style="min-width:200px">
                                @foreach (var conn in connections)
                                {
                                    <option value="@conn.Name" selected="@(conn.Name == selectedConn ? "selected" : null)">
                                        @conn.Name
                                    </option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="card-body">
                    @if (!connections.Any())
                    {
                        <div class="alert alert-warning mb-3">
                            Nenhuma conexão cadastrada. <a asp-controller="Connection" asp-action="New" class="alert-link">Cadastre uma conexão primeiro</a>.
                        </div>
                    }
                    <textarea name="SqlCommand" class="form-control font-monospace" rows="8"
                              placeholder="Digite o comando SQL aqui...&#10;Ex: SELECT * FROM tabela&#10;Ex: INSERT INTO tabela (col) VALUES ('val')&#10;Ex: CREATE TABLE teste (id INT)"
                              style="resize:vertical;">@(Model?.SqlCommand)</textarea>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary" @(!connections.Any() ? "disabled" : "")>
                        ▶ Executar
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary ms-2">← Voltar</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model != null && !string.IsNullOrEmpty(Model.SqlCommand))
{
    <div class="row">
        <div class="col-12">
            @if (!Model.Success)
            {
                <div class="card border-danger shadow-sm">
                    <div class="card-header bg-danger text-white">❌ Erro na Execução</div>
                    <div class="card-body">
                        <pre class="text-danger mb-0" style="white-space:pre-wrap;">@Model.ErrorMessage</pre>
                    </div>
                </div>
            }
            else if (Model.IsQuery)
            {
                <div class="card border-success shadow-sm">
                    <div class="card-header bg-success text-white">
                        ✅ Resultado da Consulta — @Model.Rows.Count linha(s) retornada(s)
                    </div>
                    <div class="card-body p-0">
                        @if (!Model.Columns.Any())
                        {
                            <p class="p-3 mb-0 text-muted">Nenhum resultado retornado.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover table-sm mb-0">
                                    <thead class="table-dark">
                                        <tr>
                                            @foreach (var col in Model.Columns)
                                            {
                                                <th>@col</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in Model.Rows)
                                        {
                                            <tr>
                                                @foreach (var cell in row)
                                                {
                                                    <td>@(cell ?? "<NULL>")</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card border-success shadow-sm">
                    <div class="card-header bg-success text-white">✅ Comando Executado com Sucesso</div>
                    <div class="card-body">
                        <p class="mb-0">
                            @if (Model.RowsAffected >= 0)
                            {
                                <span><strong>@Model.RowsAffected</strong> linha(s) afetada(s).</span>
                            }
                            else
                            {
                                <span>Comando DDL executado com sucesso.</span>
                            }
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
}
