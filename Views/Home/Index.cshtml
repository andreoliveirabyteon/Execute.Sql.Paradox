@model List<Execute.Sql.Paradox.Models.ConnectionConfig>
@{
    ViewData["Title"] = "Conexões";
}

<h2 class="mb-4">🗄️ Menu Principal – Conexões Disponíveis</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        Nenhuma conexão cadastrada. <a asp-controller="Connection" asp-action="New" class="alert-link">Cadastre uma nova conexão</a>.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
        @foreach (var conn in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">🔌 @conn.Name</h5>
                        @if (!string.IsNullOrWhiteSpace(conn.Server))
                        {
                            <p class="card-text text-muted mb-1"><strong>Servidor:</strong> @conn.Server</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(conn.Database))
                        {
                            <p class="card-text text-muted mb-1"><strong>Banco:</strong> @conn.Database</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(conn.Driver))
                        {
                            <p class="card-text text-muted mb-1"><strong>Driver:</strong> @conn.Driver</p>
                        }
                        <p class="card-text text-muted mb-0"><small>Criado em: @conn.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small></p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Sql" asp-action="Execute" asp-route-connectionName="@conn.Name"
                           class="btn btn-primary btn-sm">▶ Executar SQL</a>
                        <form asp-controller="Connection" asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('Remover conexão @conn.Name?')">
                            <input type="hidden" name="name" value="@conn.Name" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">🗑 Remover</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<a asp-controller="Connection" asp-action="New" class="btn btn-success">
    ➕ Nova Conexão
</a>

