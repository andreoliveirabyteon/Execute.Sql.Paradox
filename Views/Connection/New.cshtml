@model Execute.Sql.Paradox.Models.ConnectionConfig
@{
    ViewData["Title"] = "Nova Conexão";
    bool testSuccess = ViewBag.TestSuccess == true;
    bool alreadyExists = ViewBag.AlreadyExists == true;
    string? testError = ViewBag.TestError as string;
    string connType = Model.ConnectionType ?? "ODBC";
}

<h2 class="mb-4">🔌 Nova Conexão</h2>

<div class="row">
    <div class="col-md-8">
        @if (!string.IsNullOrEmpty(testError))
        {
            <div class="alert alert-danger">
                <strong>Erro ao testar conexão:</strong> @testError
            </div>
        }

        @if (testSuccess && alreadyExists)
        {
            <div class="alert alert-warning">
                <strong>Conexão testada com sucesso!</strong>
                Uma conexão com o nome <strong>@Model.Name</strong> já existe.
                Deseja sobrescrever?
                <div class="mt-2">
                    <form asp-controller="Connection" asp-action="Save" method="post" class="d-inline">
                        <input type="hidden" name="Name" value="@Model.Name" />
                        <input type="hidden" name="ConnectionType" value="@Model.ConnectionType" />
                        <input type="hidden" name="ConnectionString" value="@Model.ConnectionString" />
                        <input type="hidden" name="Driver" value="@Model.Driver" />
                        <input type="hidden" name="Server" value="@Model.Server" />
                        <input type="hidden" name="Database" value="@Model.Database" />
                        <input type="hidden" name="Username" value="@Model.Username" />
                        <input type="hidden" name="Password" value="@Model.Password" />
                        <button type="submit" class="btn btn-warning btn-sm">Sobrescrever</button>
                    </form>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm ms-2">Ir para o Menu Principal</a>
                </div>
            </div>
        }

        @if (testSuccess && !alreadyExists)
        {
            <div class="alert alert-success">
                <strong>✅ Conexão testada com sucesso!</strong>
                Deseja salvar esta conexão?
                <div class="mt-2">
                    <form asp-controller="Connection" asp-action="Save" method="post" class="d-inline">
                        <input type="hidden" name="Name" value="@Model.Name" />
                        <input type="hidden" name="ConnectionType" value="@Model.ConnectionType" />
                        <input type="hidden" name="ConnectionString" value="@Model.ConnectionString" />
                        <input type="hidden" name="Driver" value="@Model.Driver" />
                        <input type="hidden" name="Server" value="@Model.Server" />
                        <input type="hidden" name="Database" value="@Model.Database" />
                        <input type="hidden" name="Username" value="@Model.Username" />
                        <input type="hidden" name="Password" value="@Model.Password" />
                        <button type="submit" class="btn btn-success btn-sm">💾 Salvar Conexão</button>
                    </form>
                </div>
            </div>
        }

        <form asp-controller="Connection" asp-action="Test" method="post">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">Parâmetros da Conexão</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome da Conexão *</label>
                        <input type="text" name="Name" value="@Model.Name" class="form-control" required
                               placeholder="ex: MinhaConexao" />
                        <div class="form-text">Identificador único para esta conexão.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tipo de Conexão</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ConnectionType" id="typeOdbc"
                                       value="ODBC" @(connType == "ODBC" ? "checked" : "") onchange="updateConnectionTypeLabels(this.value)" />
                                <label class="form-check-label" for="typeOdbc">ODBC</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ConnectionType" id="typeOleDb"
                                       value="OleDb" @(connType == "OleDb" ? "checked" : "") onchange="updateConnectionTypeLabels(this.value)" />
                                <label class="form-check-label" for="typeOleDb">OleDb</label>
                            </div>
                        </div>
                    </div>

                    <hr />
                    <p class="text-muted">Preencha os campos individuais <strong>ou</strong> informe a string de conexão completa:</p>

                    <div class="mb-3">
                        <label id="labelDriver" class="form-label">@(connType == "OleDb" ? "Provider OleDb" : "Driver ODBC")</label>
                        <input type="text" name="Driver" value="@Model.Driver" class="form-control"
                               id="inputDriver"
                               placeholder="@(connType == "OleDb" ? "ex: Microsoft.ACE.OLEDB.12.0" : "ex: MySQL ODBC 8.0 Unicode Driver")" />
                    </div>
                    <div class="mb-3">
                        <label id="labelServer" class="form-label">@(connType == "OleDb" ? "Data Source" : "Servidor")</label>
                        <input type="text" name="Server" value="@Model.Server" class="form-control"
                               id="inputServer"
                               placeholder="@(connType == "OleDb" ? "ex: C:\\data ou servidor" : "ex: localhost ou 192.168.1.1")" />
                    </div>
                    <div class="mb-3">
                        <label id="labelDatabase" class="form-label">@(connType == "OleDb" ? "Banco de Dados (Initial Catalog)" : "Banco de Dados")</label>
                        <input type="text" name="Database" value="@Model.Database" class="form-control"
                               placeholder="ex: NomeDoBanco" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label id="labelUsername" class="form-label">@(connType == "OleDb" ? "User ID" : "Usuário")</label>
                            <input type="text" name="Username" value="@Model.Username" class="form-control"
                                   placeholder="ex: root" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Senha</label>
                            <input type="password" name="Password" value="@Model.Password" class="form-control" />
                        </div>
                    </div>

                    <hr />
                    <div class="mb-3">
                        <label class="form-label">String de Conexão Completa</label>
                        <textarea name="ConnectionString" class="form-control font-monospace" rows="3"
                                  id="inputConnectionString"
                                  placeholder="@(connType == "OleDb" ? "Provider=Microsoft.ACE.OLEDB.12.0;Data Source=C:\\data;Extended Properties=\"Paradox 5.x\";" : "Driver={MySQL ODBC 8.0 Unicode Driver};Server=localhost;Database=test;Uid=root;Pwd=secret;")">@Model.ConnectionString</textarea>
                        <div class="form-text">Se preenchida, esta string sobrescreve os campos acima.</div>
                    </div>
                </div>
                <div class="card-footer d-flex gap-2">
                    <button type="submit" class="btn btn-primary">🔍 Testar Conexão</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </div>
        </form>
    </div>

    <div class="col-md-4">
        <div class="card bg-light mb-3">
            <div class="card-header">💡 Exemplos de Strings de Conexão ODBC</div>
            <div class="card-body small">
                <p><strong>MySQL:</strong></p>
                <code class="d-block mb-2">Driver={MySQL ODBC 8.0 Unicode Driver};Server=localhost;Database=test;Uid=root;Pwd=senha;</code>
                <p><strong>SQL Server:</strong></p>
                <code class="d-block mb-2">Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=test;Uid=sa;Pwd=senha;</code>
                <p><strong>PostgreSQL:</strong></p>
                <code class="d-block mb-2">Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=test;Uid=postgres;Pwd=senha;</code>
                <p><strong>Paradox:</strong></p>
                <code class="d-block">Driver={Microsoft Paradox Driver (*.db)};DriverID=538;Fil=Paradox 5.X;DefaultDir=C:\data;Dbq=C:\data;</code>
            </div>
        </div>
        <div class="card bg-light">
            <div class="card-header">💡 Exemplos de Strings de Conexão OleDb</div>
            <div class="card-body small">
                <p><strong>Paradox (ACE):</strong></p>
                <code class="d-block mb-2">Provider=Microsoft.ACE.OLEDB.12.0;Data Source=C:\data;Extended Properties="Paradox 5.x";</code>
                <p><strong>Paradox (Jet):</strong></p>
                <code class="d-block mb-2">Provider=Microsoft.Jet.OLEDB.4.0;Data Source=C:\data;Extended Properties="Paradox 5.x;HDR=YES;";</code>
                <p><strong>SQL Server:</strong></p>
                <code class="d-block mb-2">Provider=SQLOLEDB;Data Source=localhost;Initial Catalog=test;User ID=sa;Password=senha;</code>
                <p><strong>Access:</strong></p>
                <code class="d-block">Provider=Microsoft.ACE.OLEDB.12.0;Data Source=C:\data\banco.accdb;Jet OLEDB:Database Password=senha;</code>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateConnectionTypeLabels(type) {
            const isOleDb = type === 'OleDb';
            document.getElementById('labelDriver').textContent = isOleDb ? 'Provider OleDb' : 'Driver ODBC';
            document.getElementById('inputDriver').placeholder = isOleDb ? 'ex: Microsoft.ACE.OLEDB.12.0' : 'ex: MySQL ODBC 8.0 Unicode Driver';
            document.getElementById('labelServer').textContent = isOleDb ? 'Data Source' : 'Servidor';
            document.getElementById('inputServer').placeholder = isOleDb ? 'ex: C:\\data ou servidor' : 'ex: localhost ou 192.168.1.1';
            document.getElementById('labelDatabase').textContent = isOleDb ? 'Banco de Dados (Initial Catalog)' : 'Banco de Dados';
            document.getElementById('labelUsername').textContent = isOleDb ? 'User ID' : 'Usuário';
            document.getElementById('inputConnectionString').placeholder = isOleDb
                ? 'Provider=Microsoft.ACE.OLEDB.12.0;Data Source=C:\\data;Extended Properties="Paradox 5.x";'
                : 'Driver={MySQL ODBC 8.0 Unicode Driver};Server=localhost;Database=test;Uid=root;Pwd=secret;';
        }
    </script>
}
